    {
      "name": "2. Webhook Testing Scenarios",
      "item": [
        {
          "name": "Happy Path - Pre-Sales Availability",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"booking_com\",\n  \"guest_name\": \"Priya Kapoor\",\n  \"message\": \"We are planning a getaway from April 20-24. Is Villa B1 available? How many bedrooms?\",\n  \"timestamp\": \"2024-05-12T10:00:00Z\",\n  \"booking_ref\": \"BOOK-005\",\n  \"property_id\": \"villa-b1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/message",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "message"]
            }
          }
        },
        {
          "name": "Escalation - Complaint",
          "request": {
            "method": "POST",
